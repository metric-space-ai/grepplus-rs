{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grepplus.dev/schemas/agent-coding-tasks-v2.json",
  "title": "Greppy validated agent coding benchmark tasks v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "greppy.agent-coding-tasks.v2"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "class",
        "type",
        "repository",
        "test_patch",
        "user_task",
        "setup_commands",
        "test_command",
        "timeout_seconds"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
        },
        "class": {
          "enum": [
            "S",
            "M"
          ]
        },
        "type": {
          "enum": [
            "feature-implementation",
            "reported-bugfix",
            "refactor-mit-verhalten",
            "cross-cutting-change",
            "bugfix-mit-callsite",
            "feature-parameter",
            "rename-cleanup",
            "api-migration",
            "guard/validierung",
            "config-und-code"
          ]
        },
        "repository": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "url",
            "commit"
          ],
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1,
              "description": "Credential-free repository URL."
            },
            "commit": {
              "type": "string",
              "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$",
              "description": "Full parent commit on which the task starts."
            }
          }
        },
        "test_patch": {
          "type": "string",
          "minLength": 1,
          "pattern": "^diff --git ",
          "description": "Git-apply-compatible unified diff restricted to the validated tests_touched paths."
        },
        "user_task": {
          "type": "string",
          "minLength": 1,
          "description": "Problem statement without implementation patch content."
        },
        "setup_commands": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "description": "Ordered setup argv arrays inherited from tasks_v1 for the repository."
        },
        "test_command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Validated scoped test command as an exact argv array."
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7200,
          "description": "Generous per-operation timeout; class S tasks use 1800 seconds."
        }
      }
    }
  }
}
