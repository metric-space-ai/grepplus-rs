{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "greppy.edit-plan.v1",
  "title": "greppy edit plan",
  "type": "object",
  "required": [
    "schema_version",
    "workspace",
    "operations",
    "publish"
  ],
  "properties": {
    "schema_version": {
      "const": "greppy.edit-plan.v1"
    },
    "workspace": {
      "type": "object",
      "required": [
        "root"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "expect_git_head": {
          "type": "string"
        },
        "symlinks": {
          "enum": [
            "reject",
            "follow-within-root"
          ],
          "default": "reject"
        },
        "require_unchanged_files": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "selector",
          "action"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "selector": {
            "type": "object",
            "required": [
              "engine"
            ],
            "properties": {
              "engine": {
                "enum": [
                  "symbol",
                  "tree-sitter",
                  "text",
                  "regex",
                  "data-path",
                  "lsp"
                ]
              },
              "symbol": {
                "type": "string"
              },
              "at": {
                "type": "string"
              },
              "grammar": {
                "type": "string"
              },
              "scope_query": {
                "type": "string"
              },
              "scope_capture": {
                "type": "string"
              },
              "target_query": {
                "type": "string"
              },
              "target_capture": {
                "type": "string"
              },
              "old_text": {
                "type": "string"
              },
              "pattern": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "position": {
                "type": "string"
              },
              "expect": {
                "oneOf": [
                  {
                    "const": "exactly-one"
                  },
                  {
                    "const": "zero"
                  },
                  {
                    "type": "integer",
                    "minimum": 0
                  }
                ],
                "default": "exactly-one"
              }
            }
          },
          "preconditions": {
            "type": "object",
            "properties": {
              "file_sha256": {
                "type": "string"
              },
              "target_sha256": {
                "type": "string"
              },
              "signature_fingerprint": {
                "type": "string"
              },
              "ancestor_fingerprint": {
                "type": "string"
              }
            }
          },
          "action": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "enum": [
                  "replace",
                  "patch",
                  "insert-after",
                  "insert-before",
                  "delete",
                  "rename",
                  "ensure-import",
                  "ensure-method",
                  "ensure-argument",
                  "ensure-annotation",
                  "remove-if-present",
                  "data-set",
                  "data-ensure"
                ]
              },
              "content_literal": {
                "type": "string"
              },
              "source_file": {
                "type": "string"
              },
              "patch_file": {
                "type": "string"
              },
              "fuzz": {
                "const": 0
              },
              "new_name": {
                "type": "string"
              },
              "module": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "value_json": {}
            }
          },
          "postconditions": {
            "type": "object",
            "properties": {
              "syntax": {
                "const": "no-new-errors"
              },
              "missing_nodes": {
                "const": "no-new-missing-nodes"
              },
              "changed_ranges": {
                "const": "inside-scope"
              },
              "signature_fingerprint": {
                "enum": [
                  "unchanged",
                  "changed-as-declared"
                ]
              },
              "queries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "query",
                    "expect"
                  ],
                  "properties": {
                    "query": {
                      "type": "string"
                    },
                    "within": {
                      "type": "string"
                    },
                    "capture": {
                      "type": "string"
                    },
                    "expect": {
                      "oneOf": [
                        {
                          "const": "exactly-one"
                        },
                        {
                          "const": "zero"
                        },
                        {
                          "type": "integer"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "format": {
            "type": "object",
            "properties": {
              "mode": {
                "enum": [
                  "none",
                  "selected-range",
                  "file"
                ],
                "default": "none"
              },
              "argv": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "permit_changes_outside_target": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "object",
        "oneOf": [
          {
            "required": [
              "argv"
            ]
          },
          {
            "required": [
              "shell"
            ]
          }
        ],
        "properties": {
          "argv": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "shell": {
            "type": "object",
            "required": [
              "program",
              "script"
            ],
            "properties": {
              "program": {
                "type": "string"
              },
              "script": {
                "type": "string"
              }
            }
          },
          "timeout_seconds": {
            "type": "integer",
            "default": 60
          }
        }
      }
    },
    "publish": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "atomic",
            "journal",
            "patch",
            "shadow-worktree"
          ]
        },
        "preserve": {
          "type": "array",
          "items": {
            "enum": [
              "permissions",
              "line-endings",
              "encoding"
            ]
          }
        },
        "on_failure": {
          "const": "leave-workspace-unchanged"
        }
      }
    }
  }
}
